{
  "info": {
    "name": "InventoryOrderAPI - Collection",
    "_postman_id": "inventoryorderapi-collection",
    "description": "Collection to test InventoryOrderAPI endpoints including success and error scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "createdOrderId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Order - Valid",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2,\n  \"productPrice\": 10.5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Order",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Order"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response has productId and quantity', function () {",
              "    pm.expect(json).to.have.property('productId');",
              "    pm.expect(json).to.have.property('quantity');",
              "});",
              "// save created id if present",
              "if (json && json.orderId) {",
              "    pm.environment.set('createdOrderId', json.orderId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create Order - Invalid Quantity",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 1,\n  \"quantity\": 0,\n  \"productPrice\": 10.5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Order",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Order"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Contains InvalidQuantity error code', function () {",
              "    pm.expect(json).to.have.property('Errors');",
              "    pm.expect(json.Errors[0]).to.have.property('Code', 'InvalidQuantity');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get All Orders",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Order",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Order"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response is an array', function () {",
              "    pm.expect(Array.isArray(json)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get By Id - Not Found",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Order/999999",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Order",
            "999999"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 (Not found is returned as BadRequest in this API)', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Contains OrderNotFound error code', function () {",
              "    pm.expect(json).to.have.property('Errors');",
              "    pm.expect(json.Errors[0]).to.have.property('Code', 'OrderNotFound');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete Created Order",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Order/{{createdOrderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Order",
            "{{createdOrderId}}"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Expect 204 No Content when delete succeeds",
              "pm.test('Status code is 204 or 200', function () {",
              "    pm.expect(pm.response.code === 204 || pm.response.code === 200).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete - Not Found",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Order/999999",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Order",
            "999999"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 and contains OrderNotFound', function () {",
              "    pm.response.to.have.status(400);",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('Errors');",
              "    pm.expect(json.Errors[0]).to.have.property('Code', 'OrderNotFound');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
